---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { foreignLangs, type Lang } from '../../i18n/config';
import { t } from '../../i18n/utils';

export function getStaticPaths() {
  return foreignLangs.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
const allBoards = await getCollection('boards');
const featured = allBoards
  .sort((x, y) => x.data.sortOrder - y.data.sortOrder)
  .slice(0, 4);
---

<Layout lang={lang} pagePath="/" description={t(lang, 'site_description')}>

  <section class="hero">
    <div class="hero-gallery">
      <div class="hero-img"><img src={`${b}/images/hero-1.jpg`} alt="SPREAD rider" width="1024" height="1024" fetchpriority="high" /></div>
      <div class="hero-img"><img src={`${b}/images/hero-2.jpg`} alt="SPREAD rider" width="1024" height="1024" /></div>
      <div class="hero-img"><img src={`${b}/images/hero-3.jpg`} alt="SPREAD rider" width="1024" height="1024" /></div>
    </div>
    <div class="hero-overlay">
      <img src={`${b}/images/logo-white.png`} alt="SPREAD SNOWBOARDS" class="hero-logo" />
      <p class="hero-catch">{t(lang, 'hero_catch')}</p>
    </div>
  </section>

  <section class="sub-hero">
    <div class="sub-hero-inner">
      <div class="sub-hero-text">
        <p class="hero-season">{t(lang, 'season')}</p>
        <div class="hero-actions">
          <a href={`${b}/${lang}/boards`} class="btn-primary">
            <span>BOARDS 2026/27</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={`${b}/${lang}/contact`} class="btn-outline">CONTACT</a>
        </div>
      </div>
      <div class="hero-stats">
        {[
          { num: '11', label: 'MODELS' },
          { num: '4', label: 'SERIES' },
          { num: "'17", label: 'SINCE' },
        ].map(({ num, label }) => (
          <div class="stat">
            <p class="stat-num">{num}</p>
            <p class="stat-label">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-inner">
      <div class="about-text">
        <p class="sec-tag">{t(lang, 'about_tag')}</p>
        <h2 class="about-title">
          {t(lang, 'about_title')}
          <span>{t(lang, 'about_subtitle')}</span>
        </h2>
        <div class="about-body">
          <p>{t(lang, 'about_p1')}</p>
          <p>{t(lang, 'about_p2')}</p>
        </div>
      </div>

      <div class="series-grid">
        {[
          { series: 'LT SERIES', desc: t(lang, 'series_lt'), models: 'LTA-F / LTB / LTY / LTV' },
          { series: 'X SERIES', desc: t(lang, 'series_x'), models: 'AX-F / BX / BX-F' },
          { series: 'RD SERIES', desc: t(lang, 'series_rd'), models: 'RD / RD CV' },
          { series: 'SPECIAL', desc: t(lang, 'series_special'), models: 'DX / ZERO' },
        ].map(({ series, desc, models }) => (
          <a href={`${b}/${lang}/boards`} class="series-card">
            <p class="series-name">{series}</p>
            <p class="series-desc">{desc}</p>
            <p class="series-models">{models}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="featured-inner">
      <div class="featured-header">
        <div>
          <p class="sec-tag">{t(lang, 'lineup_tag')}</p>
          <h2 class="featured-title">2026/27 BOARDS</h2>
        </div>
        <a href={`${b}/${lang}/boards`} class="view-all">
          <span>{t(lang, 'all_boards')}</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6H10M7 3L10 6L7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      </div>

      <div class="board-grid">
        {featured.map(board => (
          <a href={`${b}/${lang}/boards/${board.id}`} class="board-card">
            <div class="board-img-wrap">
              {board.data.topImage && (
                <img src={`${b}${board.data.topImage}`} alt={board.data.name} loading="lazy" />
              )}
              <span class="board-series">{board.data.series}</span>
            </div>
            <div class="board-info">
              <h3 class="board-name">{board.data.name}</h3>
              <div class="board-meta">
                <span>{board.data.design}</span>
                <div class="flex-bar">
                  {Array.from({ length: 5 }, (_, i) => (
                    <div class:list={['flex-dot', i < board.data.flex && 'active']} />
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <div class="cta-gradient"></div>
      <div class="cta-content">
        <p class="sec-tag">{t(lang, 'catalog_tag')}</p>
        <h2 class="cta-title">{t(lang, 'catalog_title')}</h2>
        <p class="cta-desc">{t(lang, 'catalog_desc')}</p>
        <a href="/SPREAD_CATALOG2026JP.pdf" target="_blank" class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1V9M4 6L7 9L10 6M2 11H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{t(lang, 'download_pdf')}</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .sec-tag { font-family: system-ui, -apple-system, sans-serif; font-size: 10px; color: #cc0000; letter-spacing: 4px; text-transform: uppercase; margin-bottom: 0.5rem; }
  .btn-primary { display: inline-flex; align-items: center; gap: 10px; background: #111; color: #fff; font-family: system-ui, -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; text-decoration: none; padding: 13px 28px; transition: background 0.2s; }
  .btn-primary:hover { background: #cc0000; color: #fff; }
  .btn-outline { display: inline-flex; align-items: center; border: 1px solid rgba(0,0,0,0.2); color: rgba(0,0,0,0.5); font-family: system-ui, -apple-system, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase; text-decoration: none; padding: 13px 28px; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: rgba(0,0,0,0.5); color: #111; }
  .hero { position: relative; overflow: hidden; background: #111; }
  .hero-gallery { display: grid; grid-template-columns: repeat(3, 1fr); }
  .hero-img { aspect-ratio: 3/4; overflow: hidden; }
  .hero-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; transition: transform 10s ease; }
  .hero:hover .hero-img img { transform: scale(1.05); }
  .hero-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,0.35); }
  .hero-logo { max-width: 360px; width: 50%; height: auto; margin-bottom: 1.25rem; }
  .hero-catch { font-family: system-ui, -apple-system, sans-serif; font-size: clamp(9px, 1.5vw, 13px); color: rgba(255,255,255,0.7); letter-spacing: 4px; }
  .sub-hero { background: #fff; padding: 3rem 1.5rem; border-bottom: 1px solid #ebebeb; }
  .sub-hero-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .hero-season { font-family: system-ui, -apple-system, sans-serif; font-size: 11px; color: rgba(0,0,0,0.4); letter-spacing: 6px; text-transform: uppercase; margin-bottom: 1rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; }
  .hero-stats { display: flex; gap: 2.5rem; }
  .stat { text-align: center; }
  .stat-num { font-family: system-ui, -apple-system, sans-serif; font-size: 36px; font-weight: 900; font-style: italic; color: #111; }
  .stat-label { font-family: system-ui, -apple-system, sans-serif; font-size: 9px; letter-spacing: 4px; color: rgba(0,0,0,0.4); text-transform: uppercase; margin-top: 4px; }
  .about { padding: 6rem 1.5rem; border-top: 1px solid #ebebeb; }
  .about-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-title { font-size: clamp(24px, 3vw, 32px); font-weight: 900; letter-spacing: 1px; font-style: italic; color: #111; line-height: 1.4; margin-bottom: 2rem; }
  .about-title span { display: block; font-size: clamp(16px, 2vw, 20px); font-weight: 300; font-style: normal; color: rgba(0,0,0,0.5); letter-spacing: 2px; margin-top: 0.25rem; }
  .about-body { display: flex; flex-direction: column; gap: 1rem; }
  .about-body p { font-size: 13px; color: rgba(0,0,0,0.65); line-height: 2; }
  .series-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .series-card { border: 1px solid rgba(0,0,0,0.08); padding: 1.25rem; text-decoration: none; background: rgba(248,248,248,0.5); transition: border-color 0.2s; }
  .series-card:hover { border-color: rgba(0,0,0,0.25); }
  .series-name { font-family: system-ui, -apple-system, sans-serif; font-size: 10px; letter-spacing: 3px; color: rgba(0,0,0,0.5); text-transform: uppercase; margin-bottom: 0.5rem; transition: color 0.2s; }
  .series-card:hover .series-name { color: #cc0000; }
  .series-desc { font-size: 14px; color: #111; font-weight: 500; margin-bottom: 0.25rem; }
  .series-models { font-size: 11px; color: rgba(0,0,0,0.5); }
  .featured { padding: 3rem 1.5rem 4rem; }
  .featured-inner { max-width: 1200px; margin: 0 auto; }
  .featured-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; }
  .featured-title { font-family: system-ui, -apple-system, sans-serif; font-size: 22px; font-weight: 900; font-style: italic; letter-spacing: 1px; color: #111; }
  .view-all { display: flex; align-items: center; gap: 6px; color: rgba(0,0,0,0.5); text-decoration: none; font-family: system-ui, -apple-system, sans-serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; transition: color 0.2s; }
  .view-all:hover { color: #111; }
  .board-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e8e8e8; }
  .board-card { background: #fff; text-decoration: none; transition: box-shadow 0.3s; }
  .board-card:hover { box-shadow: inset 0 0 0 2px #cc0000; }
  .board-img-wrap { position: relative; aspect-ratio: 1 / 2.2; background: linear-gradient(to bottom, #f5f5f5, #fafafa); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .board-img-wrap img { height: 90%; width: auto; object-fit: contain; transition: transform 0.5s; }
  .board-card:hover .board-img-wrap img { transform: scale(1.04); }
  .board-series { position: absolute; top: 12px; left: 12px; font-family: system-ui, -apple-system, sans-serif; font-size: 9px; letter-spacing: 2px; color: rgba(0,0,0,0.5); text-transform: uppercase; background: rgba(255,255,255,0.85); padding: 3px 8px; }
  .board-info { padding: 1.25rem; }
  .board-name { font-family: system-ui, -apple-system, sans-serif; font-size: 16px; font-weight: 700; letter-spacing: 3px; color: #111; text-transform: uppercase; margin-bottom: 0.75rem; transition: color 0.2s; }
  .board-card:hover .board-name { color: #cc0000; }
  .board-meta { display: flex; align-items: center; justify-content: space-between; font-family: system-ui, -apple-system, sans-serif; font-size: 10px; color: rgba(0,0,0,0.5); letter-spacing: 2px; text-transform: uppercase; }
  .flex-bar { display: flex; gap: 3px; }
  .flex-dot { width: 16px; height: 3px; background: rgba(0,0,0,0.08); }
  .flex-dot.active { background: #cc0000; }
  .cta { padding: 0 1.5rem 2rem; }
  .cta-inner { max-width: 1200px; margin: 0 auto; border: 1px solid rgba(0,0,0,0.08); padding: 4rem 3rem; text-align: center; position: relative; overflow: hidden; background: rgba(248,248,248,0.5); }
  .cta-gradient { position: absolute; inset: 0; background: linear-gradient(to right, rgba(204,0,0,0.03), transparent, transparent); }
  .cta-content { position: relative; }
  .cta-title { font-size: clamp(22px, 3vw, 28px); font-weight: 900; font-style: italic; letter-spacing: 1px; color: #111; margin-bottom: 0.75rem; }
  .cta-desc { font-size: 13px; color: rgba(0,0,0,0.5); margin-bottom: 2rem; }
  @media (max-width: 768px) {
    .hero-gallery { grid-template-columns: 1fr; }
    .hero-img:not(:first-child) { display: none; }
    .hero-img { aspect-ratio: 4/3; }
    .hero-overlay { position: static; background: #111; padding: 2rem 1.5rem; }
    .sub-hero-inner { flex-direction: column; align-items: flex-start; }
    .hero-stats { justify-content: flex-start; }
    .about-inner { grid-template-columns: 1fr; }
    .board-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-inner { padding: 3rem 1.5rem; }
  }
</style>
