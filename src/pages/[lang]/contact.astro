---
import Layout from '../../layouts/Layout.astro';
import { foreignLangs, type Lang } from '../../i18n/config';
import { t } from '../../i18n/utils';

export function getStaticPaths() {
  return foreignLangs.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout lang={lang} pagePath="/contact" title={t(lang, 'contact_title')} description={t(lang, 'contact_intro')}>

  <section class="page-header">
    <div class="page-header-inner">
      <p class="page-label">{t(lang, 'contact_tag')}</p>
      <h1 class="page-title">{t(lang, 'contact_title')}</h1>
    </div>
  </section>

  <div class="form-wrap">
    <p class="form-intro">{t(lang, 'contact_intro')}</p>

    <form name="contact" method="POST" data-netlify="true" class="contact-form">
      <input type="hidden" name="form-name" value="contact" />
      <input type="hidden" name="lang" value={lang} />

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">{t(lang, 'form_name')} <span class="required">*</span></label>
          <input type="text" name="name" required placeholder={t(lang, 'form_name_placeholder')} class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label">{t(lang, 'form_email')} <span class="required">*</span></label>
          <input type="email" name="email" required placeholder={t(lang, 'form_email_placeholder')} class="form-input" />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">{t(lang, 'form_subject')}</label>
        <select name="subject" class="form-input form-select">
          <option value="">{t(lang, 'form_subject_select')}</option>
          <option value="product">{t(lang, 'form_subject_product')}</option>
          <option value="shop">{t(lang, 'form_subject_shop')}</option>
          <option value="dealer">{t(lang, 'form_subject_dealer')}</option>
          <option value="other">{t(lang, 'form_subject_other')}</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">{t(lang, 'form_message')} <span class="required">*</span></label>
        <textarea name="message" required rows="6" placeholder={t(lang, 'form_message_placeholder')} class="form-input form-textarea"></textarea>
      </div>

      <button type="submit" class="form-submit">
        <span>{t(lang, 'form_send')}</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>
  </div>
</Layout>

<style>
  .page-header { border-bottom: 1px solid #ebebeb; padding: 3rem 1.5rem 2rem; }
  .page-header-inner { max-width: 1200px; margin: 0 auto; }
  .page-label { font-family: system-ui, -apple-system, sans-serif; font-size: 10px; letter-spacing: 4px; color: #cc0000; text-transform: uppercase; margin-bottom: 0.75rem; }
  .page-title { font-family: system-ui, -apple-system, sans-serif; font-size: clamp(32px, 5vw, 48px); font-weight: 900; font-style: italic; letter-spacing: 2px; color: #111; }
  .form-wrap { max-width: 720px; margin: 0 auto; padding: 4rem 1.5rem; }
  .form-intro { font-size: 13px; color: rgba(0,0,0,0.6); line-height: 2; margin-bottom: 3rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-label { font-family: system-ui, -apple-system, sans-serif; font-size: 10px; letter-spacing: 3px; color: rgba(0,0,0,0.5); text-transform: uppercase; }
  .required { color: #cc0000; }
  .form-input { width: 100%; background: transparent; border: 1px solid rgba(0,0,0,0.12); color: #111; font-size: 14px; padding: 12px 16px; font-family: inherit; transition: border-color 0.2s; }
  .form-input:focus { outline: none; border-color: rgba(0,0,0,0.5); }
  .form-input::placeholder { color: rgba(0,0,0,0.3); }
  .form-select { background: #fff; color: rgba(0,0,0,0.6); }
  .form-textarea { resize: none; }
  .form-submit { display: inline-flex; align-items: center; gap: 10px; align-self: flex-start; background: #111; color: #fff; border: none; cursor: pointer; font-family: system-ui, -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 13px 28px; transition: background 0.2s; }
  .form-submit:hover { background: #cc0000; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
</style>
